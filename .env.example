# ====================================================================
# AIOS BITTENSOR SUBNET - ENVIRONMENT VARIABLES TEMPLATE
# 이 파일을 복사하여 '.env' 파일로 이름을 변경한 뒤 본인의 실제 키를 입력하세요.
# 보안을 위해 '.env' 파일은 절대 GitHub에 업로드하지 마십시오.
# ====================================================================

# 1. AIOS LLM API Key (실제 마이너 연산 및 로컬 검증자 쿼리 수행 시 사용)
# OpenAI API를 사용할 때 입력하며, 입력하지 않을 경우 로컬 모사(Mock) 모드로 자동 실행됩니다.
OPENAI_API_KEY=your_openai_api_key_here

# 2. 비텐서 네트워크 설정 (실전 테스트넷/메인넷 배포 시 사용)
# NETUID=99
# WALLET_NAME=default
# WALLET_HOTKEY=default
# SUBTENSOR_NETWORK=mock # mock, local, test, finney
